# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local dev (default): SQLite, zero setup. Prisma resolves this path relative
# to the /prisma folder.
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL): switch `provider` in prisma/schema.prisma to
# "postgresql" and use a connection string like the one below (matches
# docker-compose.yml). Then run: npm run db:push && npm run db:seed
# DATABASE_URL="postgresql://examuser:exampass@localhost:5432/examprep?schema=public"

# ---------------------------------------------------------------------------
# AI question generation (optional — only for growing GK/GS/English banks).
# The provider is auto-detected from whichever key is set (free ones preferred).
# ---------------------------------------------------------------------------

# FREE option 1 — Google Gemini (no billing/card needed):
#   Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash-lite"

# FREE option 2 — Groq (no billing/card needed):
#   Get a key at https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# FREE option 3 — OpenRouter (one key, many free models: DeepSeek/Qwen/Llama):
#   Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="deepseek/deepseek-chat-v3-0324:free"

# Paid option — OpenAI:
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Force a provider (optional): "gemini" | "groq" | "openai". Leave blank to auto-detect.
AI_PROVIDER=""

# Admin key guarding the AI generation endpoint (/api/admin/generate).
ADMIN_KEY="dev-admin"

# ---------------------------------------------------------------------------
# Authentication — Clerk (https://dashboard.clerk.com)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"

# Comma-separated emails granted admin access to /admin.
ADMIN_EMAILS=""

# ---------------------------------------------------------------------------
# Production database (Neon Postgres). Pooled URL for the app, direct URL for
# Prisma migrations. Set both in Vercel for production.
# ---------------------------------------------------------------------------
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Secret protecting the daily current-affairs cron (/api/cron/sync-current-affairs).
CRON_SECRET="dev-cron-change-me"
